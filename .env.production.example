# ============================================
# Marketplace Unisabana — Produccion
# ============================================
# Copia este archivo a .env y completa los valores
# Luego: docker compose -f docker-compose.prod.yml up -d
#
# Variables marcadas con * son REQUERIDAS

# === Postgres (Docker) ===
# * Contrasena de la base de datos
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD
POSTGRES_USER=postgres
POSTGRES_DB=marketplace_unisabana

# === Backend ===
# DATABASE_URL con pool parameters (connection_limit, pool_timeout, connect_timeout)
DATABASE_URL=postgresql://postgres:CHANGE_ME_GENERATE_STRONG_PASSWORD@postgres:5432/marketplace_unisabana?connection_limit=10&pool_timeout=10&connect_timeout=10

# * Secreta JWT (generar con: openssl rand -hex 64)
JWT_SECRET=CHANGE_ME_RUN_openssl_rand_hex_64
JWT_EXPIRES_IN=7d

# Origenes CORS permitidos (separados por coma)
CORS_ORIGINS=https://tu-dominio.com

# URL publica del frontend (para enlaces en emails, etc.)
FRONTEND_URL=https://tu-dominio.com

# Nivel de log: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# === Cloudinary (imagenes) ===
# Opcional: si esta vacio, usa almacenamiento local (no funciona en Docker)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# === OAuth ===
# * Requerido en produccion para verificar tokens
GOOGLE_CLIENT_ID=

# Opcional: Microsoft / Azure AD
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=common

# === Error Tracking ===
SENTRY_DSN=

# === Email (SendGrid) ===
# Opcional: si esta vacio, solo se registra en log
SENDGRID_API_KEY=
FROM_EMAIL=noreply@marketplacesabana.com
FROM_NAME=Marketplace Sabana

# === Backups (cron) ===
# Dias de retencion de backups
BACKUP_RETENTION_DAYS=30
# Host de la DB (para backup script desde fuera del contenedor)
PGHOST=localhost
PGPORT=5432
