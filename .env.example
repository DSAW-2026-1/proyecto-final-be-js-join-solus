# ============================================
# Marketplace Unisabana - Variables de Entorno
# ============================================
# Copia este archivo a .env y completa los valores

# --- Base de Datos (PostgreSQL) ---
# Local: postgresql://canilomoncada@localhost:5432/marketplace_unisabana
# Docker: postgresql://postgres:postgres@localhost:5432/marketplace_unisabana
# Vercel: URL de Neon / Supabase / AWS RDS
DATABASE_URL="postgresql://canilomoncada@localhost:5432/marketplace_unisabana"

# --- JWT (jsonwebtoken) ---
JWT_SECRET="marketplace-unisabana-production-secret-change-me"
JWT_EXPIRES_IN="7d"

# --- Cloudinary (Imágenes) ---
# Opcional: si está vacío, usa almacenamiento local (no funciona en Vercel)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --- Sentry (error tracking) ---
# Opcional: si está vacío, no se inicializa Sentry
SENTRY_DSN=""
NODE_ENV="development"

# --- CORS ---
# Orígenes permitidos separados por coma
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# --- Puerto del servidor ---
PORT=8080

# --- Frontend (para .env.production) ---
# VITE_API_BASE_URL=https://tu-backend.vercel.app
