{
  "name": "marketplace-unisabana-server",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node -r dotenv/config index.js",
    "start:pm2": "pm2-runtime ecosystem.config.js --env production",
    "dev": "node --watch -r dotenv/config index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "node -r dotenv/config prisma/seed.js",
    "setup": "prisma generate && prisma migrate dev && node -r dotenv/config prisma/seed.js",
    "production": "prisma migrate deploy && node -r dotenv/config index.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^10.53.1",
    "cloudinary": "^1.41.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "pino": "^10.3.1",
    "prisma": "^5.22.0",
    "socket.io": "^4.8.3",
    "xss": "^1.0.15",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "vitest": "^4.1.7"
  }
}
